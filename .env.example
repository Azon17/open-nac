###############################################################################
#  Open NAC System — Environment Configuration
#  Скопируйте в .env и измените все значения changeme_*
###############################################################################

# ── MariaDB Galera ──────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=changeme_root_pwd
MYSQL_DATABASE=radius
MYSQL_USER=radius
MYSQL_PASSWORD=changeme_radius_pwd
GALERA_BACKUP_PWD=changeme_backup_pwd

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_pwd

# ── EJBCA (PKI) ────────────────────────────────────────────────────────────
EJBCA_DB_USER=ejbca
EJBCA_DB_PASSWORD=changeme_ejbca_pwd

# ── Fingerbank (Profiling) ─────────────────────────────────────────────────
# Получите бесплатный API key: https://fingerbank.org/
FINGERBANK_API_KEY=

# ── Fleet (Posture / osquery management) ───────────────────────────────────
FLEET_SERVER_URL=http://fleet:8080
FLEET_API_TOKEN=

# ── Guest Portal ────────────────────────────────────────────────────────────
PORTAL_SECRET_KEY=changeme_portal_secret
PORTAL_OAUTH2_ENABLED=true
PORTAL_SMS_ENABLED=false

# ── Admin UI ────────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY=changeme_admin_secret

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana_pwd

# ── Profiling ───────────────────────────────────────────────────────────────
NMAP_SCAN_ENABLED=false
NMAP_SCAN_INTERVAL=3600

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
