{
  "uid": "opennac-galera-health",
  "title": "Galera Cluster Health",
  "description": "MariaDB Galera cluster monitoring — replication, sync state, flow control",
  "tags": ["opennac", "galera", "mariadb", "database"],
  "timezone": "browser",
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Cluster Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { "expr": "mysql_global_status_wsrep_cluster_size", "legendFormat": "Nodes" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Node State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        { "expr": "mysql_global_status_wsrep_local_state", "legendFormat": "State (4=Synced)" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Joining", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "Donor/Desynced", "color": "orange" } } },
            { "type": "value", "options": { "3": { "text": "Joined", "color": "yellow" } } },
            { "type": "value", "options": { "4": { "text": "Synced", "color": "green" } } }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 4 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "WSREP Ready",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        { "expr": "mysql_global_status_wsrep_ready", "legendFormat": "Ready" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "YES", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "NO", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Connections (used / max)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        { "expr": "mysql_global_status_threads_connected / mysql_global_variables_max_connections * 100", "legendFormat": "%" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "QPS",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "rate(mysql_global_status_queries[5m])", "legendFormat": "QPS" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "title": "Slow Queries/s",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        { "expr": "rate(mysql_global_status_slow_queries[5m])", "legendFormat": "Slow/s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Replication — Send Queue / Recv Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "mysql_global_status_wsrep_local_send_queue_avg", "legendFormat": "Send Queue Avg" },
        { "expr": "mysql_global_status_wsrep_local_recv_queue_avg", "legendFormat": "Recv Queue Avg" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 11,
      "title": "Flow Control — Paused Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "rate(mysql_global_status_wsrep_flow_control_paused_ns[5m]) / 1e9", "legendFormat": "Paused (sec/sec)" },
        { "expr": "rate(mysql_global_status_wsrep_flow_control_sent[5m])", "legendFormat": "FC Messages/s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 12,
      "title": "InnoDB Buffer Pool Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "100 * (1 - rate(mysql_global_status_innodb_buffer_pool_reads[5m]) / (rate(mysql_global_status_innodb_buffer_pool_read_requests[5m]) + 0.001))",
          "legendFormat": "Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Write Operations",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "targets": [
        { "expr": "rate(mysql_global_status_innodb_row_ops_total{operation=\"inserted\"}[5m])", "legendFormat": "Inserts/s" },
        { "expr": "rate(mysql_global_status_innodb_row_ops_total{operation=\"updated\"}[5m])", "legendFormat": "Updates/s" },
        { "expr": "rate(mysql_global_status_innodb_row_ops_total{operation=\"deleted\"}[5m])", "legendFormat": "Deletes/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 14,
      "title": "Certification Conflicts",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "targets": [
        { "expr": "rate(mysql_global_status_wsrep_local_cert_failures[5m])", "legendFormat": "Cert Failures/s" },
        { "expr": "rate(mysql_global_status_wsrep_local_bf_aborts[5m])", "legendFormat": "BF Aborts/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 39
}
