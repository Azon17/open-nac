{
  "uid": "opennac-nac-overview",
  "title": "NAC Overview",
  "description": "Open NAC — System 360 overview: services, resources, RADIUS, Galera, alerts, certificates",
  "tags": ["opennac", "overview", "system360"],
  "timezone": "browser",
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Service health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"freeradius\"}", "legendFormat": "FreeRADIUS" },
        { "expr": "up{job=\"mariadb-galera\"}", "legendFormat": "MariaDB/Galera" },
        { "expr": "up{job=\"redis\"}", "legendFormat": "Redis" },
        { "expr": "up{job=\"kafka\"}", "legendFormat": "Kafka" },
        { "expr": "up{job=\"policy-engine\"}", "legendFormat": "Policy Engine" },
        { "expr": "up{job=\"posture-engine\"}", "legendFormat": "Posture Engine" },
        { "expr": "up{job=\"profiler\"}", "legendFormat": "Profiler" },
        { "expr": "up{job=\"nginx\"}", "legendFormat": "Admin UI" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "CPU",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 4 },
      "targets": [
        { "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 3,
      "title": "Memory",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 4 },
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "Mem %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 4,
      "title": "Disk /",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 4 },
      "targets": [
        { "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "legendFormat": "Disk %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 85 }, { "color": "red", "value": 92 }] } } }
    },
    {
      "id": 5,
      "title": "RADIUS auth rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 4 },
      "targets": [
        { "expr": "rate(freeradius_total_access_accepts[1m])", "legendFormat": "Accepts/s" },
        { "expr": "rate(freeradius_total_access_rejects[1m])", "legendFormat": "Rejects/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Rejects/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Accepts/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 6,
      "title": "Reject rate %",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 3, "x": 18, "y": 4 },
      "targets": [
        { "expr": "100 * rate(freeradius_total_access_rejects[5m]) / (rate(freeradius_total_access_accepts[5m]) + rate(freeradius_total_access_rejects[5m]) + 0.001)", "legendFormat": "Reject %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "orange", "value": 30 }, { "color": "red", "value": 60 }] } } }
    },
    {
      "id": 7,
      "title": "Connected endpoints",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 4 },
      "targets": [
        { "expr": "policy_engine_connected_endpoints", "legendFormat": "Endpoints" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "graphMode": "area" }
    },
    {
      "id": 8,
      "title": "Galera cluster",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 7 },
      "targets": [
        { "expr": "mysql_global_status_wsrep_cluster_size", "legendFormat": "Nodes" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 2 }, { "color": "green", "value": 3 }] } } }
    },
    {
      "id": 10,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])", "legendFormat": "RX {{ device }}" },
        { "expr": "-rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])", "legendFormat": "TX {{ device }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30 } } }
    },
    {
      "id": 11,
      "title": "Kafka consumer lag",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "targets": [
        { "expr": "kafka_consumergroup_lag_sum", "legendFormat": "{{ consumergroup }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 12,
      "title": "Redis memory & connections",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "Memory Used" },
        { "expr": "redis_connected_clients", "legendFormat": "Connections" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Connections" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      }
    },
    {
      "id": 20,
      "title": "Active alerts",
      "type": "alertlist",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "options": { "showOptions": "current", "sortOrder": 1, "stateFilter": { "firing": true, "pending": true }, "dashboardAlerts": false }
    },
    {
      "id": 21,
      "title": "TCP probes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "probe_success{job=\"blackbox-tcp\"}", "legendFormat": "{{ instance }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 22,
      "title": "Certificate expiry (days)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400", "legendFormat": "{{ instance }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 7 }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] }
        }
      },
      "options": { "colorMode": "background" }
    }
  ],
  "schemaVersion": 39
}
