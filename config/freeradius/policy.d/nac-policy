#==================================================================
#  MAC Address Normalization
#  Приводит MAC к единому формату: aa:bb:cc:dd:ee:ff (lowercase, colons)
#==================================================================

policy mac_normalize {
	if (&Calling-Station-Id) {
		update request {
			&Calling-Station-Id := "%{tolower:%{Calling-Station-Id}}"
		}

		#--- Заменяем разделители на двоеточия ---
		if (&Calling-Station-Id =~ /^([0-9a-f]{2})[-.]([0-9a-f]{2})[-.]([0-9a-f]{2})[-.]([0-9a-f]{2})[-.]([0-9a-f]{2})[-.]([0-9a-f]{2})$/) {
			update request {
				&Calling-Station-Id := "%{1}:%{2}:%{3}:%{4}:%{5}:%{6}"
			}
		}

		#--- Cisco WLC формат: xxxx.xxxx.xxxx ---
		if (&Calling-Station-Id =~ /^([0-9a-f]{2})([0-9a-f]{2})\.([0-9a-f]{2})([0-9a-f]{2})\.([0-9a-f]{2})([0-9a-f]{2})$/) {
			update request {
				&Calling-Station-Id := "%{1}:%{2}:%{3}:%{4}:%{5}:%{6}"
			}
		}
	}
}

#==================================================================
#  Wireless SSID extraction
#  Из Called-Station-Id (AP_MAC:SSID_NAME) извлекаем SSID
#==================================================================

policy nac_extract_ssid {
	if (&Called-Station-Id =~ /^([0-9a-fA-F:.-]+):(.+)$/) {
		update request {
			&X-NAC-SSID := "%{2}"
			&X-NAC-AP-MAC := "%{tolower:%{1}}"
		}
	}
}

