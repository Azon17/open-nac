###############################################################################
#  Open NAC — unlang Policy Rules
#  Эквивалент: Cisco ISE Authorization Policy + Policy Sets
#
#  Эти правила выполняются внутри FreeRADIUS (быстро, без REST-вызова)
#  для базовых решений. Сложная логика делегируется policy-engine.
#
#  Порядок приоритета:
#    1. unlang rules (этот файл) — мгновенные решения
#    2. SQL group-based auth — VLAN из radgroupreply
#    3. REST → policy-engine — сложные условия, profiling, posture
#
#  При отказе policy-engine: unlang + SQL обеспечивают fallback
###############################################################################

#==================================================================
#  VLAN Assignment по AD-группам (базовый, без policy-engine)
#  Эквивалент: ISE Authorization Rule "If AD-Group = X then VLAN Y"
#==================================================================

policy nac_vlan_by_group {
	#--- Domain Admins → Management VLAN ---
	if (&LDAP-Group[*] =~ /CN=Domain Admins/) {
		update reply {
			&Tunnel-Type := VLAN
			&Tunnel-Medium-Type := IEEE-802
			&Tunnel-Private-Group-Id := "10"
		}
	}

	#--- IT Department → IT VLAN ---
	elsif (&LDAP-Group[*] =~ /CN=IT-Department/) {
		update reply {
			&Tunnel-Type := VLAN
			&Tunnel-Medium-Type := IEEE-802
			&Tunnel-Private-Group-Id := "100"
		}
	}

	#--- Все сотрудники → Employee VLAN ---
	elsif (&LDAP-Group[*] =~ /CN=Domain Users/) {
		update reply {
			&Tunnel-Type := VLAN
			&Tunnel-Medium-Type := IEEE-802
			&Tunnel-Private-Group-Id := "100"
		}
	}

	#--- Контракторы ---
	elsif (&LDAP-Group[*] =~ /CN=Contractors/) {
		update reply {
			&Tunnel-Type := VLAN
			&Tunnel-Medium-Type := IEEE-802
			&Tunnel-Private-Group-Id := "200"
		}
	}

	#--- Не удалось определить группу → Quarantine ---
	else {
		update reply {
			&Tunnel-Type := VLAN
			&Tunnel-Medium-Type := IEEE-802
			&Tunnel-Private-Group-Id := "999"
		}
	}
}

#==================================================================
#  URL Redirect для Captive Portal
#  Эквивалент: ISE Authorization Profile с Web Redirect
#==================================================================

policy nac_captive_portal_redirect {
	#--- Cisco: используем AVPair ---
	if (&NAS-Vendor == 9) {
		update reply {
			&Cisco-AVPair += "url-redirect-acl=ACL-WEBAUTH-REDIRECT"
			&Cisco-AVPair += "url-redirect=https://portal.nac.local:8443/guest/register?mac=%{tolower:%{Calling-Station-Id}}"
		}
	}

	#--- Juniper: используем Juniper-Switching-Filter ---
	elsif (&NAS-Vendor == 2636) {
		update reply {
			&Juniper-Switching-Filter := "match destination-port 80 then redirect https://portal.nac.local:8443/guest/register"
		}
	}

	#--- Aruba/HPE: используем URL-redirect ---
	elsif (&NAS-Vendor == 14823) {
		update reply {
			&Aruba-Port-Bounce-Host := 0
			&Reply-Message := "https://portal.nac.local:8443/guest/register?mac=%{tolower:%{Calling-Station-Id}}"
		}
	}

	#--- Generic: Filter-Id ---
	else {
		update reply {
			&Filter-Id := "REDIRECT-TO-PORTAL"
		}
	}
}

